# === LLM Configuration ===
SSA_LLM_BASE_URL=https://api.mistral.ai/v1
SSA_LLM_MODEL_NAME=mistral-large-latest
SSA_LLM_API_KEY=

# === Database ===
SSA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sanctions_db

# === S3 (Data Lake) ===
SSA_S3_BUCKET=sanctions-data
SSA_S3_REGION=eu-central-1
SSA_AWS_ACCESS_KEY_ID=
SSA_AWS_SECRET_ACCESS_KEY=

# === Embedding Model ===
# Dev (8GB RAM): sentence-transformers/all-MiniLM-L6-v2 (90MB, 384-dim)
# Prod (16GB+):  BAAI/bge-m3 (2.3GB, 1024-dim, multilingual)
SSA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SSA_EMBEDDING_DIM=384

# === Two-Pass Ingestion ===
# Set to true to store text chunks without embeddings (pass 1)
# Then run backfill_embeddings.py to embed in batches (pass 2)
SSA_SKIP_EMBEDDINGS=false
BACKFILL_BATCH_SIZE=25

# === Observability ===
SSA_LANGSMITH_API_KEY=
SSA_LANGSMITH_PROJECT=sanctions-screening-assistant

# === Application ===
SSA_LOG_LEVEL=INFO
SSA_CORS_ORIGINS=["http://localhost:3000"]

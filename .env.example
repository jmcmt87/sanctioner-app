# === LLM Configuration ===
SSA_LLM_BASE_URL=https://api.mistral.ai/v1
SSA_LLM_MODEL_NAME=mistral-large-latest
SSA_LLM_API_KEY=

# === Database ===
SSA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sanctions_db

# === S3 (Data Lake) ===
SSA_S3_BUCKET=sanctions-data
SSA_S3_REGION=eu-central-1
SSA_AWS_ACCESS_KEY_ID=
SSA_AWS_SECRET_ACCESS_KEY=

# === Embedding Model ===
SSA_EMBEDDING_MODEL_NAME=BAAI/bge-m3
SSA_EMBEDDING_MODEL_PATH=

# === Observability ===
SSA_LANGSMITH_API_KEY=
SSA_LANGSMITH_PROJECT=sanctions-screening-assistant

# === Application ===
SSA_LOG_LEVEL=INFO
SSA_CORS_ORIGINS=["http://localhost:3000"]
